{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "VegettableApi": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ApiSettings": {
    "Cache": {
      "FarmTransMinutes": 10,
      "ProductsMinutes": 5,
      "SearchMinutes": 30,
      "HistoricalMinutes": 60,
      "FishMinutes": 10,
      "LivestockMinutes": 10,
      "OrganicMinutes": 30
    },
    "BackgroundService": {
      "FetchIntervalMinutes": 30,
      "StartupDelaySeconds": 10,
      "MaxConsecutiveFailures": 3,
      "MaxBackoffMinutes": 30
    },
    "Prediction": {
      "DaysAhead": 7,
      "LinearWeight": 0.7,
      "SeasonalWeight": 0.3,
      "UpThresholdPercent": 3.0,
      "DownThresholdPercent": -3.0,
      "MinPrice": 0.1
    },
    "Market": {
      "DefaultQueryDays": 7,
      "CompareQueryDays": 3,
      "DefaultCompareCount": 5
    }
  }
}
