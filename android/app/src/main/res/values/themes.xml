<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Liquid Glass 主題 (iOS 26 / visionOS 風格) -->
    <style name="Theme.Vegettable" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryContainer">@color/primary_light</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/primary_light</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <!-- Liquid Glass 卡片 -->
    <style name="GlassCard">
        <item name="cardBackgroundColor">@color/glass_bg</item>
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/glass_stroke</item>
    </style>

    <!-- Liquid Glass 膠囊晶片 -->
    <style name="CategoryChip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">24dp</item>
        <item name="chipMinHeight">38dp</item>
    </style>
</resources>
